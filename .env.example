# Telegram API Credentials
# Get these from https://my.telegram.org/auth
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Bot Token
# Get this from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Bot Owner IDs
# Your Telegram user ID(s) - supports multiple owners separated by commas
# You can get your ID from @userinfobot
# Examples:
# Single owner: OWNER_IDS=123456789
# Multiple owners: OWNER_IDS=123456789,987654321
OWNER_IDS=your_telegram_user_id_here

# Legacy support (will be used if OWNER_IDS is not set)
OWNER_ID=your_telegram_user_id_here

# Encryption Key for Session Storage
# Generate a strong random key or use the default (change for production)
ENCRYPTION_KEY=your_strong_encryption_key_here

# MongoDB Configuration
# Free MongoDB Atlas URL - Get from https://cloud.mongodb.com/
MONGO_DB_URL=mongodb+srv://username:password@cluster.mongodb.net/telegram_bot?retryWrites=true&w=majority

# Optional Configuration
SESSIONS_DIR=sessions
LOG_LEVEL=INFO
LOG_FILE=bot.log
BROADCAST_DELAY=1.0
MAX_RETRIES=3
